{
    "name": "wazen/sdk",
    "description": "Official PHP SDK for the Wazen WhatsApp API",
    "type": "library",
    "license": "MIT",
    "keywords": ["wazen", "whatsapp", "api", "sdk"],
    "homepage": "https://wazen.dev",
    "authors": [
        {
            "name": "IrixSoft",
            "email": "support@irixsoft.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Wazen\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wazen\\Laravel\\WazenServiceProvider"
            ],
            "aliases": {
                "Wazen": "Wazen\\Laravel\\WazenFacade"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
